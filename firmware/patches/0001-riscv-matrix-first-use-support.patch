--- a/arch/riscv/kernel/matrix.c
+++ b/arch/riscv/kernel/matrix.c
@@ -0,0 +1,62 @@
+// SPDX-License-Identifier: GPL-2.0-only
+#include <linux/uaccess.h>
+#include <asm/matrix.h>
+#include <asm/insn.h>
+
+#define RVG_OPCODE_CUSTOM0	0x0b
+#define RVG_OPCODE_CUSTOM1	0x2b
+#define RVG_OPCODE_CUSTOM2	0x5b
+#define RVG_OPCODE_CUSTOM3	0x7b
+
+#define CSR_XMCSR_FIRST		0x802
+#define CSR_XMCSR_LAST		0x80a
+#define CSR_XMINFO_FIRST	0xcc0
+#define CSR_XMINFO_LAST		0xcc7
+
+static bool insn_is_matrix(u32 insn_buf)
+{
+	u32 opcode = insn_buf & __INSN_OPCODE_MASK;
+	u32 csr;
+
+	/* Matrix instructions and CSR ops are expected to be 4-byte. */
+	if (unlikely(GET_INSN_LENGTH(insn_buf) != 4))
+		return false;
+
+	switch (opcode) {
+	case RVG_OPCODE_CUSTOM0:
+	case RVG_OPCODE_CUSTOM1:
+	case RVG_OPCODE_CUSTOM2:
+	case RVG_OPCODE_CUSTOM3:
+		return true;
+	case RVG_OPCODE_SYSTEM:
+		csr = RVG_EXTRACT_SYSTEM_CSR(insn_buf);
+		if ((csr >= CSR_XMCSR_FIRST && csr <= CSR_XMCSR_LAST) ||
+		    (csr >= CSR_XMINFO_FIRST && csr <= CSR_XMINFO_LAST))
+			return true;
+		break;
+	}
+
+	return false;
+}
+
+bool riscv_m_first_use_handler(struct pt_regs *regs)
+{
+	u32 __user *epc = (u32 __user *)regs->epc;
+	u32 insn = (u32)regs->badaddr;
+
+	/* If MS has been enabled then this is not a first-use trap. */
+	if (riscv_m_vstate_query(regs))
+		return false;
+
+	if (!insn) {
+		if (__get_user(insn, epc))
+			return false;
+	}
+
+	if (!insn_is_matrix(insn))
+		return false;
+
+	/* Minimal support: allow retry with MS set to initial state. */
+	riscv_m_vstate_on(regs);
+	return true;
+}

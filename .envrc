# ── xsai-env-316 root .envrc ──────────────────────────────────────────────────
# Rich direnv workflow: Nix devshell + shared env + local overrides + submodule hints.

if declare -F hide_env_diff >/dev/null 2>&1; then
  hide_env_diff
fi

watch_file flake.nix flake.lock .envrc.base .envrc.local scripts/env-common.sh
if command -v nix >/dev/null 2>&1; then
  use flake
else
  log_status "nix not found; falling back to .envrc.base only (recommended: install Nix and use the flake devshell via direnv or make nix-shell)"
fi

export _ENVRC_ENTRY=root
source_env ".envrc.base"
unset _ENVRC_ENTRY

# Layer 2: local overrides (machine-specific, secrets) — NOT tracked by git
# Copy .envrc.local.example → .envrc.local to get started
if [[ -f ".envrc.local" ]]; then
  source_env ".envrc.local"
fi

# Submodule check — at most once per shell session (keyed on SHLVL+PPID)
source "${XS_PROJECT_ROOT}/scripts/check-submodule-updates.sh"
_submod_flag="${XS_PROJECT_ROOT}/.direnv/.checked_${SHLVL}_${PPID}"
mkdir -p "${XS_PROJECT_ROOT}/.direnv"
if [[ ! -f "$_submod_flag" ]]; then
  touch "$_submod_flag"
  find "${XS_PROJECT_ROOT}/.direnv" -name ".checked_*" -mmin +60 -delete 2>/dev/null
  check_submodule_updates "${XS_PROJECT_ROOT}"
fi
unset _submod_flag
# NOTE: when entering a subdirectory (e.g. XSAI/), this file is re-executed by
# direnv automatically. The flag above prevents double-printing within the same
# shell session. Each subdirectory's .envrc then calls check_submodule_updates
# for its own repo only.